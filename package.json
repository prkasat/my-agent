{
	"name": "my-agent",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"build": "tsc -b packages/ai packages/core packages/cli",
		"dev": "tsc -b --watch packages/ai packages/core packages/cli",
		"test": "vitest",
		"lint": "biome check .",
		"format": "biome format --write .",
		"clean": "rm -rf packages/*/dist"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^25.5.2",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0"
	}
}
