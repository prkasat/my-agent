{
	"name": "my-agent",
	"private": true,
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prkasat/my-agent.git"
	},
	"bugs": {
		"url": "https://github.com/prkasat/my-agent/issues"
	},
	"homepage": "https://github.com/prkasat/my-agent#readme",
	"workspaces": [
		"packages/*"
	],
	"engines": {
		"node": ">=22.19.0"
	},
	"scripts": {
		"build": "tsc -b packages/ai packages/core packages/cli",
		"dev": "tsc -b --watch packages/ai packages/core packages/cli",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"format": "biome format --write .",
		"eval:mock": "npm run build && node scripts/eval.mjs",
		"clean": "rm -rf packages/*/dist"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/node": "^25.9.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	}
}
