# OpenRouter is the only API-key provider in this build.
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional: required only if you want Anthropic OAuth login support.
ANTHROPIC_OAUTH_CLIENT_ID=your-anthropic-oauth-client-id

# Optional: override the built-in public OpenAI Codex OAuth client id.
OPENAI_CODEX_OAUTH_CLIENT_ID=your-openai-codex-oauth-client-id

# Optional: enable structured JSONL tracing.
MY_AGENT_TRACE=0
MY_AGENT_TRACE_SCOPES=runtime,auth,rpc,permissions,extensions,resources

# Optional: disable helper binary downloads.
MY_AGENT_OFFLINE=0
